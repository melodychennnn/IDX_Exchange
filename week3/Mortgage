import os
import pandas as pd
os.chdir("/Users/Melody/Downloads/idx")

listings = pd.read_csv("data/combined_listings.csv", low_memory=False)
sold = pd.read_csv("data/combined_sold.csv", low_memory=False)

print(f"Sold:     {len(sold):,} rows loaded")
print(f"Listings: {len(listings):,} rows loaded")

# Fetch FRED mortgage rate data
url = "https://fred.stlouisfed.org/graph/fredgraph.csv?id=MORTGAGE30US"
mortgage = pd.read_csv(url, parse_dates=["observation_date"])
mortgage.columns = ["date", "rate_30yr_fixed"]
print(f"\nFRED data fetched: {len(mortgage)} weekly records")
print(f"Date range: {mortgage['date'].min().date()} to {mortgage['date'].max().date()}")

# Resample weekly to monthly average 
mortgage["year_month"] = mortgage["date"].dt.to_period("M")
mortgage_monthly = (
    mortgage.groupby("year_month")["rate_30yr_fixed"]
    .mean()
    .reset_index()
)
mortgage_monthly["rate_30yr_fixed"] = mortgage_monthly["rate_30yr_fixed"].round(2)
print(f"Resampled to {len(mortgage_monthly)} monthly averages")

# Preview monthly rates
print("\n-- Sample Monthly Rates --")
print(mortgage_monthly.tail(6).to_string(index=False))

# Create year_month keys on MLS datasets 
sold["year_month"] = pd.to_datetime(sold["CloseDate"], errors="coerce").dt.to_period("M")
listings["year_month"] = pd.to_datetime(listings["ListingContractDate"], errors="coerce").dt.to_period("M")

# Merge 
sold_with_rates = sold.merge(mortgage_monthly, on="year_month", how="left")
listings_with_rates = listings.merge(mortgage_monthly, on="year_month", how="left")

# Validate 
sold_nulls = sold_with_rates["rate_30yr_fixed"].isnull().sum()
listings_nulls = listings_with_rates["rate_30yr_fixed"].isnull().sum()

print(f"\nNull rates in sold after merge:     {sold_nulls}")
print(f"Null rates in listings after merge: {listings_nulls}")

if sold_nulls == 0 and listings_nulls == 0:
    print("✓ No null rates — merge successful!")
else:
    print("⚠ Some null rates found — check year_month keys")
    # Show which months didn't match
    unmatched = sold_with_rates[sold_with_rates["rate_30yr_fixed"].isnull()]["year_month"].unique()
    print(f"Unmatched months: {unmatched}")

print("Sold Preview (CloseDate, year_month, ClosePrice, rate_30yr_fixed) --")
print(sold_with_rates[["CloseDate", "year_month", "ClosePrice", "rate_30yr_fixed"]].head(5).to_string(index=False))

sold_with_rates.to_csv("data/sold_with_rates.csv", index=False)
listings_with_rates.to_csv("data/listings_with_rates.csv", index=False)

print(f"\nSaved sold_with_rates.csv:     {len(sold_with_rates):,} rows")
print(f"Saved listings_with_rates.csv: {len(listings_with_rates):,} rows")
